{
  "name": "healthcare-finder-nz",
  "version": "0.1.0",
  "private": true,
  "description": "Static NZ mental health and healthcare support finder with local provider data validation tools.",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "check:syntax": "node tools/check-syntax.mjs",
    "validate": "npm run check:syntax && npm run validate:data",
    "validate:data": "node tools/validate-provider-data.mjs",
    "audit": "npm run audit:source-fit && npm run audit:availability && npm run audit:referrals && npm run audit:quality && npm run audit:support-preferences && npm run audit:addresses && npm run audit:watchlist",
    "audit:availability": "node tools/audit-provider-availability.mjs",
    "audit:referrals": "node tools/audit-psychiatrist-referrals.mjs",
    "recheck:availability": "node tools/recheck-provider-availability.mjs",
    "audit:source-fit": "node tools/audit-provider-source-fit.mjs",
    "audit:quality": "node tools/audit-provider-quality.mjs providers.json",
    "audit:support-preferences": "node tools/audit-support-preferences.mjs providers.json",
    "audit:addresses": "node tools/audit-address-coverage.mjs providers.json",
    "audit:watchlist": "node tools/audit-availability-watchlist.mjs",
    "evidence:graph": "node tools/build-provider-evidence-graph.mjs",
    "evidence:score": "node tools/score-provider-claims.mjs",
    "evidence:conflicts": "node tools/detect-provider-conflicts.mjs",
    "scan:identities": "node tools/scan-provider-identities.mjs",
    "export:review": "node tools/export-provider-review-queue.mjs",
    "export:claims": "node tools/export-provider-claim-review-queue.mjs",
    "export:auto-resolution": "node tools/export-provider-auto-resolution-proposals.mjs",
    "export:gp-corroboration": "node tools/export-gp-source-corroboration-queue.mjs",
    "export:gp-review-pack": "node tools/export-gp-corroboration-review-pack.mjs",
    "export:regional-quality": "node tools/export-regional-data-quality-report.mjs",
    "export:source-fit-capture": "node tools/export-source-fit-evidence-capture.mjs",
    "draft:claim-batch": "node tools/draft-claim-batch-review-decisions.mjs",
    "export:monitor": "node tools/export-provider-monitor-queue.mjs",
    "monitor:providers": "node tools/recheck-provider-availability.mjs --include-live && node tools/audit-provider-availability.mjs && node tools/export-provider-monitor-queue.mjs",
    "apply:review": "node tools/apply-provider-review-decisions.mjs",
    "discover:providers": "node tools/build-provider-discovery-queue.mjs",
    "discover:seeds": "node tools/build-provider-discovery-seeds.mjs",
    "discover:enrich": "node tools/enrich-provider-candidates.mjs",
    "discover:suggest": "node tools/build-provider-suggestions.mjs",
    "discover:places": "node tools/discover-google-places-providers.mjs",
    "discover:report": "node tools/enrich-provider-candidates.mjs --no-network --limit 50 && node tools/build-provider-suggestions.mjs",
    "check:links": "node tools/check-links.mjs"
  },
  "engines": {
    "node": ">=22"
  }
}
